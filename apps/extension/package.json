{
  "name": "@cognifillz/extension",
  "version": "0.1.0",
  "description": "CogniFillz Chrome Extension",
  "scripts": {
    "dev": "webpack --config webpack.chrome.js --mode development --watch",
    "dev:chrome": "webpack --config webpack.chrome.js --mode development --watch",
    "dev:firefox": "webpack --config webpack.firefox.js --mode development --watch",
    "build": "npm run build:chrome && npm run build:firefox",
    "build:chrome": "webpack --config webpack.chrome.js --mode production",
    "build:firefox": "webpack --config webpack.firefox.js --mode production",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.39.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "webextension-polyfill": "^0.12.0"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.258",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@types/webextension-polyfill": "^0.12.4",
    "copy-webpack-plugin": "^12.0.2",
    "css-loader": "^6.10.0",
    "html-webpack-plugin": "^5.6.0",
    "style-loader": "^3.3.4",
    "ts-loader": "^9.5.1",
    "typescript": "^5.3.3",
    "webpack": "^5.90.0",
    "webpack-cli": "^5.1.4",
    "webpack-merge": "^6.0.1"
  }
}
