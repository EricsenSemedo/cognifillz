# LM Studio endpoint (default)
LLM_BASE_URL=http://localhost:1234/v1
LLM_API_KEY=not-needed-for-local

# Alternative: Ollama
# LLM_BASE_URL=http://localhost:11434/v1

# Alternative: Cloud fallback (OpenAI)
